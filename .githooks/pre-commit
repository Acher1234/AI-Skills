#!/usr/bin/env bash
#
# 🔒 Pre-commit hook — gitleaks
# Bloque le commit si un secret (clé API, token, mot de passe...) est détecté
# dans les changements indexés (staged).
#
# Installation : voir README.md → "Installation des hooks"
#   git config core.hooksPath .githooks
#
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 1. Vérifie que gitleaks est installé
if ! command -v gitleaks >/dev/null 2>&1; then
  echo -e "${RED}✖ gitleaks introuvable.${NC}"
  echo -e "${YELLOW}  Installe-le puis réessaie :${NC}"
  echo "    macOS  : brew install gitleaks"
  echo "    Linux  : apt-get install gitleaks   (ou télécharge depuis github.com/gitleaks/gitleaks/releases)"
  echo ""
  echo -e "${YELLOW}  Pour bypasser exceptionnellement (déconseillé) : git commit --no-verify${NC}"
  exit 1
fi

echo -e "${YELLOW}🔍 gitleaks : analyse des changements indexés...${NC}"

# 2. Analyse uniquement les changements staged (rapide, pertinent pour un commit)
#    gitleaks >= 8.19 : `git --staged`  |  versions plus anciennes : `protect --staged`
if gitleaks git --help >/dev/null 2>&1; then
  SCAN_CMD=(gitleaks git --staged --redact --verbose)
else
  SCAN_CMD=(gitleaks protect --staged --redact --verbose)
fi

if ! "${SCAN_CMD[@]}"; then
  echo ""
  echo -e "${RED}✖ Commit bloqué : un secret potentiel a été détecté.${NC}"
  echo -e "${YELLOW}  Retire le secret des fichiers indexés, puis recommite.${NC}"
  echo -e "${YELLOW}  Faux positif ? Ajoute une règle d'exclusion dans .gitleaks.toml${NC}"
  echo -e "${YELLOW}  (ou, en dernier recours : git commit --no-verify)${NC}"
  exit 1
fi

echo -e "${GREEN}✔ Aucun secret détecté. Commit autorisé.${NC}"
exit 0
